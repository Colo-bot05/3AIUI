APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@db:5432/three_ai_ui
# MEETING_PROVIDER=mock   (デフォルト)
# MEETING_PROVIDER=anthropic に切り替えて ANTHROPIC_API_KEY を設定すると実 API が使われる
MEETING_PROVIDER=mock
ANTHROPIC_API_KEY=

# --- AWS IaC (infra/) ---
# ローカル開発では不要。infra:deploy 時に aws configure 済みの profile を使います。
AWS_REGION=ap-northeast-1
# CDK bootstrap 済みの AWS アカウント ID（infra:deploy のターゲット）
# AWS_ACCOUNT_ID=123456789012
